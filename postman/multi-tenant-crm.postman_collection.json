                "exec": [
                  "var r = pm.response.json().results || [];",
                  "if (r.length) pm.collectionVariables.set('stage_id', r[0].id);",
                  "var won = r.find(function(s){return s.is_won;});",
                  "if (won) pm.collectionVariables.set('won_stage_id', won.id);"
